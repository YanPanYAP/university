{
  "name": "trvp-lab6-docker-mssql-nginx",
  "version": "1.0.0",
  "private": true,
  "description": "ТРВП ЛР6: MSSQL in Docker + TDWA06-01 CRUD + NGINX reverse proxy",
  "main": "src/server.js",
  "scripts": {
    "install:node": "npm install",
    "start": "DB_NAME=Celebrities node ./src/server.js",
    "start:direct": "DB_NAME=Celebrities DB_PORT=14333 node ./src/server.js",
    "start:proxy": "DB_NAME=Celebrities DB_PORT=15433 node ./src/server.js",
    "docker:up": "docker compose -f ./docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f ./docker/docker-compose.yml down",
    "docker:restart:mssql": "docker compose -f ./docker/docker-compose.yml restart mssql",
    "docker:logs": "docker compose -f ./docker/docker-compose.yml logs -f --tail=150",
    "db:init": "node ./scripts/run-sql.js ./sql/01-create-db.sql",
    "db:dml": "DB_NAME=Celebrities node ./scripts/run-sql.js ./sql/02-dml-check.sql",
    "db:init:proxy": "DB_PORT=15433 node ./scripts/run-sql.js ./sql/01-create-db.sql",
    "db:dml:proxy": "DB_NAME=Celebrities DB_PORT=15433 node ./scripts/run-sql.js ./sql/02-dml-check.sql"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "mssql": "^11.0.1"
  }
}
